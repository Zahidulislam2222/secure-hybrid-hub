{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Hybrid: Initialize Runtime",
      "type": "process",
      "command": "python3",
      "args": ["${workspaceFolder}/hybrid-hub/hub.py", "--runtime", "${workspaceFolder}/hybrid-hub/runtime", "init-runtime"],
      "problemMatcher": []
    },
    {
      "label": "Hybrid: Run Local-Only Task",
      "type": "process",
      "command": "python3",
      "args": ["${workspaceFolder}/hybrid-hub/hub.py", "--runtime", "${workspaceFolder}/hybrid-hub/runtime", "run", "${input:hybridRequest}", "--system", "${input:hybridSystem}", "--through", "local-ready"],
      "problemMatcher": {
        "owner": "hybrid-hub",
        "fileLocation": "absolute",
        "pattern": {"regexp": "^.*\\\"message\\\": \\\"(.*)\\\".*$", "message": 1}
      }
    },
    {
      "label": "Hybrid: Status",
      "type": "process",
      "command": "python3",
      "args": ["${workspaceFolder}/hybrid-hub/hub.py", "--runtime", "${workspaceFolder}/hybrid-hub/runtime", "status", "${input:hybridTask}"],
      "problemMatcher": []
    },
    {
      "label": "Hybrid: Emergency Stop",
      "type": "process",
      "command": "python3",
      "args": ["${workspaceFolder}/hybrid-hub/hub.py", "--runtime", "${workspaceFolder}/hybrid-hub/runtime", "emergency-stop"],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {"id": "hybridRequest", "type": "promptString", "description": "Task request (never paste credentials or regulated records)"},
    {"id": "hybridSystem", "type": "promptString", "description": "Registered system ID"},
    {"id": "hybridTask", "type": "promptString", "description": "Task ID"}
  ]
}
